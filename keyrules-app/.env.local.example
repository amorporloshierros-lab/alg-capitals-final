# =============================================================
# KeyRules × ALG Capitals — Environment Variables
# Copy to .env.local and fill in before running the app.
# NEVER commit .env.local to git.
# =============================================================

# ----- Supabase -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ----- MercadoPago --------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=<access-token>
MERCADOPAGO_WEBHOOK_SECRET=<webhook-secret>

# ----- Stripe -------------------------------------------------
STRIPE_SECRET_KEY=sk_live_<key>
STRIPE_WEBHOOK_SECRET=whsec_<secret>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<key>

# ----- Mux ---------------------------------------------------
MUX_TOKEN_ID=<token-id>
MUX_TOKEN_SECRET=<token-secret>
MUX_SIGNING_KEY_ID=<signing-key-id>
MUX_SIGNING_PRIVATE_KEY=<base64-encoded-private-key>

# ----- Resend (emails) ----------------------------------------
RESEND_API_KEY=re_<key>
RESEND_FROM_EMAIL=noreply@keyrules.com

# ----- App ----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Chatbot (backend de Lucas) ----------------------------
NEXT_PUBLIC_CHATBOT_URL=https://outsell-crimson-cheese.ngrok-free.dev/api/chat

# ----- Posthog analytics -------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=<phc_key>
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
